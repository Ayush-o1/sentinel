# =============================================================================
# SENTINEL — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ----- Application -----
APP_ENV=development          # development | staging | production
APP_NAME=SENTINEL
APP_VERSION=1.0.0
DEBUG=true

# ----- Backend Server -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ----- Security (CHANGE THESE IN PRODUCTION) -----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Database (PostgreSQL) -----
# Ask your DBA for production credentials — never hardcode here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=your_postgres_password_here
# Full async connection URL (constructed from above in config.py)
# DATABASE_URL is built programmatically — do not set manually

# ----- CORS -----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- Rate Limiting -----
RATE_LIMIT_PREDICT=30/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute

# ----- ML Model -----
# Path relative to backend/app/ml/models/
ACTIVE_MODEL_VERSION=1.0.0
MODEL_FILE_NAME=sentinel_v1.0.0.joblib

# ----- Frontend -----
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=SENTINEL
VITE_APP_VERSION=1.0.0
