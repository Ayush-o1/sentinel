# ----- Python / Backend -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
backend/.venv/
backend/venv/

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# ----- Environment Variables -----
.env
.env.local
.env.development
.env.production
.env.*.local
backend/.env
frontend/.env
!.env.example
!backend/.env.example
!frontend/.env.example

# ----- Machine Learning -----
# Dataset files (can be large)
ml/data/raw/
ml/data/processed/
# Trained model files
backend/app/ml/models/*.pkl
# Keep the .gitkeep placeholder
!backend/app/ml/models/.gitkeep
# Jupyter checkpoints
ml/notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/

# ----- Node.js / Frontend -----
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# Build output
frontend/dist/
frontend/build/
*.local

# ----- OS & Editors -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/settings.json
*.sublime-project
*.sublime-workspace

# ----- Docker -----
# Keep docker files, ignore any local override secrets
docker-compose.override.yml

# ----- Logs -----
logs/
*.log
backend/logs/

# ----- Database -----
*.db
*.sqlite
*.sqlite3

# ----- Misc -----
.cache/
tmp/
temp/
venv312/
